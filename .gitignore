# macOS
.DS_Store
Thumbs.db

# Xcode
build/
DerivedData/
*.xcuserstate
xcuserdata/
*.xcscmblueprint
*.xccheckout

# XcodeGen が project.yml から生成する成果物(コミットしない。ADR-0004)。
# usage string 等の正典は project.yml。Info.plist もそこから生成する。
/Mimizuku.xcodeproj/
/App/Info.plist

# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# Secrets / signing (never commit; also enforced by CI gitleaks)
.env
.env.*
!.env.example
*.p12
*.mobileprovision
*.cer

# Recorded audio / transcripts must never be committed
*.caf
*.wav
sessions/

# AI agent personal-local files (not shared with the team)
CLAUDE.local.md
.claude/settings.local.json

# 個人用ローカル領域(README 以外は追跡しない)
/local/*
!/local/README.md

# ベンダリング成果物(scripts/build-webrtc-apm.sh が生成する。ADR-0013)
/Vendor/

# MkDocs build output
site/
_site/

# Editor
.idea/
*.swp
